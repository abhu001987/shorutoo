<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Strait Navigator — Chart the Waters</title>
<style>
  :root{
    --void:#03050b;
    --ocean-deep:#061a2c;
    --ocean-mid:#0c3452;
    --ocean-hi:#164a6e;
    --land:#8a5a2e;
    --land-hi:#d99a52;
    --land-rim:#ffcf7a;
    --gold:#ffd166;
    --coral:#ff5d73;
    --teal:#5eead4;
    --glass:rgba(10,20,35,0.55);
    --glass-brd:rgba(255,214,102,0.25);
    --ink:#eaf2f7;
    --ink-dim:#9db3c4;
  }
  *{box-sizing:border-box;}
  html,body{
    margin:0;padding:0;height:100%;overflow:hidden;
    background:var(--void);
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    color:var(--ink);
  }
  body{
    position:relative;
    background:radial-gradient(ellipse at 30% 20%, #0a1730 0%, var(--void) 55%);
  }
  /* starfield */
  #stars, #stars2{
    position:fixed;inset:0;z-index:0;pointer-events:none;
  }
  .twinkle{animation:tw 4s ease-in-out infinite;}
  @keyframes tw{0%,100%{opacity:.25}50%{opacity:1}}

  #app{position:relative;z-index:1;height:100%;display:flex;flex-direction:column;}

  /* ---------- HUD ---------- */
  #hud-top{
    display:flex;align-items:center;justify-content:space-between;gap:14px;
    padding:14px 18px;
    background:linear-gradient(to bottom, rgba(3,5,11,0.85), rgba(3,5,11,0));
    z-index:5;
  }
  .brand{
    font-weight:800;letter-spacing:.14em;font-size:12px;color:var(--teal);
    text-transform:uppercase;opacity:.85;
  }
  .strait-card{
    background:var(--glass);
    border:1px solid var(--glass-brd);
    backdrop-filter:blur(10px);
    border-radius:14px;
    padding:10px 18px;
    text-align:center;
    box-shadow:0 0 30px rgba(255,209,102,0.08);
  }
  .strait-card .eyebrow{font-size:10px;letter-spacing:.2em;color:var(--ink-dim);text-transform:uppercase;}
  .strait-card .title{font-size:clamp(16px,3.4vw,24px);font-weight:800;color:var(--gold);letter-spacing:.02em;margin-top:2px;text-shadow:0 0 18px rgba(255,209,102,0.35);}
  #dots{display:flex;gap:5px;justify-content:center;margin-top:8px;}
  .dot{width:6px;height:6px;border-radius:50%;background:#2a3d52;transition:.2s;}
  .dot.done{background:var(--teal);box-shadow:0 0 6px var(--teal);}
  .dot.now{background:var(--gold);box-shadow:0 0 8px var(--gold);transform:scale(1.4);}

  .score-pill{
    background:var(--glass);border:1px solid var(--glass-brd);border-radius:100px;
    padding:8px 16px;font-size:13px;font-weight:700;color:var(--ink-dim);white-space:nowrap;
  }
  .score-pill b{color:var(--teal);}

  /* ---------- MAP ---------- */
  #map-viewport{
    flex:1;position:relative;overflow:hidden;
    margin:0 10px;
    border-radius:18px;
    border:1px solid rgba(94,234,212,0.15);
    box-shadow:0 0 60px rgba(6,26,44,0.6) inset, 0 0 40px rgba(0,0,0,0.4);
  }
  #map-viewport.mobile{overflow-x:auto;overflow-y:hidden;-webkit-overflow-scrolling:touch;}
  #map-viewport.mobile::-webkit-scrollbar{height:6px;}
  #map-viewport.mobile::-webkit-scrollbar-thumb{background:rgba(94,234,212,.4);border-radius:4px;}
  svg#worldmap{display:block;height:100%;width:100%;cursor:crosshair;touch-action:pan-x;}
  #map-viewport.mobile svg#worldmap{width:1500px;max-width:none;height:100%;}
  .swipe-hint{
    position:absolute;bottom:10px;left:50%;transform:translateX(-50%);
    font-size:11px;color:var(--ink-dim);letter-spacing:.08em;text-transform:uppercase;
    background:rgba(3,5,11,0.6);padding:6px 12px;border-radius:100px;pointer-events:none;
    z-index:4;opacity:0;transition:opacity .3s;
  }
  #map-viewport.mobile .swipe-hint{opacity:1;}

  .land{fill:url(#landGrad);stroke:var(--land-rim);stroke-width:1;filter:drop-shadow(0 0 5px rgba(255,207,122,0.35));}
  .grat{stroke:rgba(94,234,212,0.09);stroke-width:.6;fill:none;}
  .ocean-glow{animation:pulseGlow 6s ease-in-out infinite;}
  @keyframes pulseGlow{0%,100%{opacity:.5}50%{opacity:.9}}

  .pin-guess circle.core{fill:var(--coral);}
  .pin-guess circle.ring{fill:none;stroke:var(--coral);stroke-width:1.6;}
  .pin-target circle.core{fill:var(--gold);}
  .pin-target circle.ring{fill:none;stroke:var(--gold);stroke-width:1.6;}
  .ping{fill:none;stroke:var(--coral);stroke-width:2;opacity:.9;animation:ping 1s ease-out forwards;}
  @keyframes ping{from{r:2;opacity:.9;stroke-width:2.5;}to{r:26;opacity:0;stroke-width:.3;}}
  .link-line{stroke:var(--ink-dim);stroke-width:1;stroke-dasharray:3 3;opacity:.6;}

  /* ---------- BOTTOM PANEL ---------- */
  #hud-bottom{
    z-index:5;padding:14px 18px 18px;
    display:flex;flex-direction:column;align-items:center;gap:10px;
  }
  #feedback{
    width:100%;max-width:640px;
    background:var(--glass);border:1px solid var(--glass-brd);backdrop-filter:blur(10px);
    border-radius:14px;padding:12px 18px;text-align:center;
    display:none;
  }
  #feedback.show{display:block;}
  #feedback .verdict{font-weight:800;font-size:15px;}
  #feedback .verdict.good{color:var(--teal);}
  #feedback .verdict.mid{color:var(--gold);}
  #feedback .verdict.bad{color:var(--coral);}
  #feedback .fact{font-size:12.5px;color:var(--ink-dim);margin-top:4px;line-height:1.4;}

  .btn{
    border:none;border-radius:100px;padding:13px 30px;font-size:14px;font-weight:800;
    letter-spacing:.04em;cursor:pointer;transition:transform .12s ease, box-shadow .2s;
    text-transform:uppercase;
  }
  .btn:active{transform:scale(.96);}
  .btn-primary{background:linear-gradient(135deg,var(--gold),#ff9f5a);color:#241200;box-shadow:0 0 24px rgba(255,209,102,0.35);}
  .btn-primary:hover{box-shadow:0 0 34px rgba(255,209,102,0.55);}
  .btn-ghost{background:transparent;border:1px solid var(--glass-brd);color:var(--ink-dim);}
  .hint-tap{font-size:12px;color:var(--ink-dim);letter-spacing:.05em;opacity:.8;}

  /* ---------- OVERLAY SCREENS ---------- */
  .screen{
    position:fixed;inset:0;z-index:20;display:flex;align-items:center;justify-content:center;
    background:radial-gradient(ellipse at 50% 30%, #0a1c34 0%, var(--void) 70%);
    text-align:center;padding:24px;
  }
  .screen.hidden{display:none;}
  .panel{max-width:520px;}
  .kicker{font-size:11px;letter-spacing:.3em;color:var(--teal);text-transform:uppercase;margin-bottom:14px;}
  h1{font-size:clamp(30px,6vw,46px);margin:0 0 12px;color:var(--ink);letter-spacing:.01em;}
  h1 span{color:var(--gold);text-shadow:0 0 30px rgba(255,209,102,.4);}
  .sub{color:var(--ink-dim);font-size:14.5px;line-height:1.6;margin-bottom:28px;}
  .radar{
    width:170px;height:170px;margin:0 auto 26px;border-radius:50%;
    border:1px solid rgba(94,234,212,0.3);position:relative;overflow:hidden;
    background:radial-gradient(circle, rgba(94,234,212,0.06), transparent 70%);
  }
  .radar::before, .radar::after{content:"";position:absolute;border-radius:50%;border:1px solid rgba(94,234,212,0.15);}
  .radar::before{inset:22px;}
  .radar::after{inset:44px;}
  .sweep{
    position:absolute;inset:0;border-radius:50%;
    background:conic-gradient(from 0deg, rgba(94,234,212,0.45), transparent 35%);
    animation:spin 3s linear infinite;
  }
  @keyframes spin{to{transform:rotate(360deg);}}
  .final-score{font-size:52px;font-weight:800;color:var(--gold);text-shadow:0 0 26px rgba(255,209,102,.4);}
  .final-label{color:var(--ink-dim);font-size:13px;letter-spacing:.1em;text-transform:uppercase;margin-top:-6px;margin-bottom:26px;}
</style>
</head>
<body>

<canvas id="stars"></canvas>

<div id="app">

  <!-- START SCREEN -->
  <div class="screen" id="screen-start">
    <div class="panel">
      <div class="radar"><div class="sweep"></div></div>
      <div class="kicker">Satellite Geo Ops</div>
      <h1>Strait <span>Navigator</span></h1>
      <p class="sub">Thirteen legendary straits. One world map. You'll be given a name — pin its approximate location on the globe. Close counts. Precision earns glory.</p>
      <button class="btn btn-primary" onclick="startGame()">Begin Mission</button>
    </div>
  </div>

  <!-- END SCREEN -->
  <div class="screen hidden" id="screen-end">
    <div class="panel">
      <div class="kicker">Mission Complete</div>
      <div class="final-score" id="final-score">0%</div>
      <div class="final-label">Average Navigation Accuracy</div>
      <p class="sub" id="final-msg"></p>
      <button class="btn btn-primary" onclick="startGame()">Chart Again</button>
    </div>
  </div>

  <!-- GAME UI -->
  <div id="hud-top">
    <div class="brand">◆ Strait Navigator</div>
    <div class="strait-card">
      <div class="eyebrow" id="round-label">Round 1 of 13</div>
      <div class="title" id="strait-name">—</div>
      <div id="dots"></div>
    </div>
    <div class="score-pill">Accuracy <b id="score-live">0%</b></div>
  </div>

  <div id="map-viewport">
    <svg id="worldmap" viewBox="0 0 1000 500" preserveAspectRatio="xMidYMid slice">
      <defs>
        <linearGradient id="oceanGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#0c3452"/>
          <stop offset="55%" stop-color="#071e33"/>
          <stop offset="100%" stop-color="#04101d"/>
        </linearGradient>
        <linearGradient id="landGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#d99a52"/>
          <stop offset="100%" stop-color="#7c4e26"/>
        </linearGradient>
        <radialGradient id="glow" cx="30%" cy="20%" r="80%">
          <stop offset="0%" stop-color="rgba(94,234,212,0.14)"/>
          <stop offset="100%" stop-color="rgba(94,234,212,0)"/>
        </radialGradient>
      </defs>
      <rect x="0" y="0" width="1000" height="500" fill="url(#oceanGrad)"/>
      <rect x="0" y="0" width="1000" height="500" fill="url(#glow)" class="ocean-glow"/>
      <g id="graticule"></g>
      <g id="landmasses"></g>
      <g id="markers"></g>
    </svg>
    <div class="swipe-hint">← slide to explore the map →</div>
  </div>

  <div id="hud-bottom">
    <div id="feedback">
      <div class="verdict" id="verdict-text"></div>
      <div class="fact" id="fact-text"></div>
    </div>
    <div class="hint-tap" id="tap-hint">Tap or click anywhere on the map to drop your pin</div>
    <button class="btn btn-primary" id="next-btn" style="display:none" onclick="nextRound()">Next Strait →</button>
  </div>

</div>

<script>
/* ---------------- Starfield background ---------------- */
(function(){
  const c = document.getElementById('stars');
  const ctx = c.getContext('2d');
  function resize(){ c.width = innerWidth; c.height = innerHeight; }
  resize(); addEventListener('resize', resize);
  const stars = Array.from({length:220}, () => ({
    x: Math.random()*innerWidth, y: Math.random()*innerHeight,
    r: Math.random()*1.4+0.2, s: Math.random()*0.02+0.005, p: Math.random()*Math.PI*2
  }));
  function draw(t){
    ctx.clearRect(0,0,c.width,c.height);
    for(const st of stars){
      const a = 0.35 + 0.65*Math.abs(Math.sin(t*st.s + st.p));
      ctx.globalAlpha = a;
      ctx.fillStyle = '#cfe9ff';
      ctx.beginPath(); ctx.arc(st.x, st.y, st.r, 0, Math.PI*2); ctx.fill();
    }
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();

/* ---------------- Projection ---------------- */
const W = 1000, H = 500;
function project(lon, lat){
  return { x: (lon + 180) * (W/360), y: (90 - lat) * (H/180) };
}
function toPath(coords){
  return coords.map((c,i)=>{
    const p = project(c[0], c[1]);
    return (i===0?'M':'L') + p.x.toFixed(1) + ',' + p.y.toFixed(1);
  }).join(' ') + ' Z';
}

/* ---------------- Landmasses (simplified) ---------------- */
const LANDMASSES = [
  [[-165,68],[-155,60],[-135,58],[-125,49],[-124,40],[-117,33],[-105,22],[-97,16],[-88,14],[-84,9],[-80,8],[-81,25],[-75,35],[-70,42],[-65,45],[-55,50],[-65,60],[-80,62],[-95,68],[-110,70],[-130,70],[-150,70],[-165,68]],
  [[-77,8],[-80,5],[-81,0],[-80,-5],[-81,-15],[-75,-20],[-70,-25],[-70,-35],[-73,-45],[-68,-55],[-65,-52],[-58,-38],[-48,-25],[-35,-10],[-40,0],[-50,5],[-60,8],[-77,8]],
  [[-17,21],[-16,15],[-11,7],[-8,5],[3,6],[9,4],[9,-1],[12,-6],[12,-18],[18,-34],[26,-33],[33,-27],[35,-22],[40,-15],[40,-5],[43,0],[42,5],[48,12],[43,13],[37,15],[33,22],[35,28],[32,31],[25,32],[10,37],[0,35],[-6,33],[-9,30],[-17,21]],
  [[-10,36],[-9,43],[-2,43],[0,44],[3,43],[8,44],[10,45],[13,46],[14,45],[19,42],[23,40],[26,40],[29,41],[35,42],[28,45],[30,46],[38,47],[48,47],[52,45],[55,45],[52,42],[48,40],[45,37],[48,30],[56,27],[61,25],[68,24],[72,22],[78,9],[80,13],[85,20],[90,22],[95,20],[98,10],[100,7],[104,10],[107,20],[110,22],[115,23],[120,24],[122,30],[121,31],[122,37],[128,38],[130,42],[135,44],[140,45],[142,46],[145,48],[155,60],[160,65],[170,68],[178,68],[170,70],[150,72],[130,74],[110,73],[90,73],[70,70],[60,68],[55,66],[40,66],[33,68],[28,70],[20,69],[25,60],[30,60],[28,55],[24,54],[20,54],[14,54],[10,54],[5,51],[-2,49],[-5,48],[-4,44],[-10,43],[-10,36]],
  [[113,-22],[114,-26],[115,-33],[118,-35],[125,-33],[131,-32],[136,-35],[140,-38],[145,-38],[150,-37],[153,-28],[153,-24],[146,-19],[142,-11],[137,-12],[132,-12],[130,-13],[126,-14],[122,-17],[113,-22]],
  [[-45,60],[-42,60],[-22,70],[-20,75],[-30,82],[-45,82],[-55,70],[-55,65],[-45,60]],
  [[43,-12],[47,-13],[50,-16],[47,-25],[44,-25],[43,-20],[43,-12]],
  [[-5,58],[-3,58],[0,52],[1,51],[-5,50],[-6,52],[-8,55],[-5,58]],
  [[130,32],[132,34],[136,35],[140,36],[141,40],[145,43],[142,45],[140,41],[138,37],[135,34],[130,32]],
  [[95,5],[98,2],[104,-2],[105,-6],[99,3],[95,5]],
  [[105,-6],[110,-7],[114,-8],[108,-6],[105,-6]],
  [[109,4],[117,4],[119,-1],[114,-4],[109,1],[109,4]],
  [[120,18],[122,14],[125,10],[121,16],[120,18]],
  [[173,-41],[175,-37],[178,-38],[175,-42],[168,-45],[173,-41]],
  [[121,25],[122,24],[121,22],[120,23],[120,24.5],[121,25]],
  [[80,9.5],[81.5,9],[81.8,7],[80,6],[79.7,8],[80,9.5]]
];

function drawLandmasses(){
  const g = document.getElementById('landmasses');
  g.innerHTML = LANDMASSES.map(c => `<path class="land" d="${toPath(c)}"/>`).join('');
}

function drawGraticule(){
  const g = document.getElementById('graticule');
  let out = '';
  for(let lon=-180; lon<=180; lon+=30){
    const a = project(lon,90), b = project(lon,-90);
    out += `<line class="grat" x1="${a.x}" y1="${a.y}" x2="${b.x}" y2="${b.y}"/>`;
  }
  for(let lat=-60; lat<=60; lat+=30){
    const a = project(-180,lat), b = project(180,lat);
    out += `<line class="grat" x1="${a.x}" y1="${a.y}" x2="${b.x}" y2="${b.y}"/>`;
  }
  g.innerHTML = out;
}

/* ---------------- Strait data ---------------- */
const STRAITS = [
  {name:"Strait of Malacca", lat:2.8, lon:100.9, fact:"The busiest shipping corridor on Earth, threading between Malaysia, Sumatra and Singapore to link the Indian and Pacific Oceans."},
  {name:"Strait of Hormuz", lat:26.6, lon:56.3, fact:"A narrow gap between Iran and Oman that a huge share of the world's seaborne oil must pass through."},
  {name:"Strait of Gibraltar", lat:35.95, lon:-5.6, fact:"Separates Europe from Africa in just 14km, joining the Atlantic Ocean to the Mediterranean Sea."},
  {name:"Bab-el-Mandeb", lat:12.6, lon:43.4, fact:"Arabic for 'Gate of Tears' — it links the Red Sea to the Gulf of Aden between Yemen and the Horn of Africa."},
  {name:"Bosporus Strait", lat:41.1, lon:29.06, fact:"Runs straight through Istanbul, connecting the Black Sea to the Sea of Marmara and splitting a city across two continents."},
  {name:"Dardanelles Strait", lat:40.2, lon:26.4, fact:"Links the Aegean Sea to the Sea of Marmara — site of the fierce WWI Gallipoli campaign."},
  {name:"Bering Strait", lat:65.7, lon:-169.0, fact:"Just 82km of icy water separates Russia from Alaska here — the narrowest gap between Asia and North America."},
  {name:"English Channel", lat:50.2, lon:-1.5, fact:"The stretch of sea dividing southern England from northern France, crossed by ferries, swimmers and a tunnel."},
  {name:"Strait of Dover", lat:51.0, lon:1.4, fact:"The Channel's narrowest pinch point — only about 33km separate England from France here."},
  {name:"Taiwan Strait", lat:24.5, lon:119.6, fact:"Separates the island of Taiwan from mainland China's Fujian coast."},
  {name:"Sunda Strait", lat:-6.0, lon:105.9, fact:"Sits between Java and Sumatra, linking the Java Sea to the Indian Ocean, with volcanic Krakatoa nearby."},
  {name:"Mozambique Channel", lat:-17.5, lon:41.5, fact:"A wide channel between Madagascar and the African mainland, rich with coral reefs and marine life."},
  {name:"Palk Strait", lat:9.8, lon:79.6, fact:"The shallow stretch of water separating India from Sri Lanka."}
];

/* ---------------- Game state ---------------- */
let order = [];
let roundIdx = 0;
let scores = [];
let guessed = false;

function shuffle(arr){
  const a = arr.slice();
  for(let i=a.length-1;i>0;i--){
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]]=[a[j],a[i]];
  }
  return a;
}

function haversine(lat1,lon1,lat2,lon2){
  const R = 6371;
  const dLat = (lat2-lat1)*Math.PI/180;
  const dLon = (lon2-lon1)*Math.PI/180;
  const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
  return R * 2*Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

function setupDots(){
  const dots = document.getElementById('dots');
  dots.innerHTML = order.map((_,i)=>`<div class="dot" id="dot-${i}"></div>`).join('');
}
function updateDots(){
  order.forEach((_,i)=>{
    const d = document.getElementById('dot-'+i);
    d.classList.toggle('done', i < roundIdx);
    d.classList.toggle('now', i === roundIdx);
  });
}

function startGame(){
  order = shuffle(STRAITS);
  roundIdx = 0; scores = [];
  document.getElementById('screen-start').classList.add('hidden');
  document.getElementById('screen-end').classList.add('hidden');
  setupDots();
  loadRound();
}

function loadRound(){
  guessed = false;
  document.getElementById('markers').innerHTML = '';
  document.getElementById('feedback').classList.remove('show');
  document.getElementById('next-btn').style.display = 'none';
  document.getElementById('tap-hint').style.display = 'block';
  document.getElementById('round-label').textContent = `Round ${roundIdx+1} of ${order.length}`;
  document.getElementById('strait-name').textContent = order[roundIdx].name;
  updateDots();
}

function verdictFor(km){
  if(km < 250) return {label:'Bullseye — spot on!', cls:'good'};
  if(km < 600) return {label:'Excellent placement!', cls:'good'};
  if(km < 1200) return {label:'Nearby — solid instinct.', cls:'mid'};
  if(km < 2500) return {label:'Right ocean, rough spot.', cls:'mid'};
  return {label:'Way off course — but noted.', cls:'bad'};
}

function scoreFor(km){
  return Math.max(0, Math.round(100 - km/40));
}

const svg = document.getElementById('worldmap');
svg.addEventListener('click', onMapClick);

function onMapClick(evt){
  if(guessed) return;
  guessed = true;

  const pt = svg.createSVGPoint();
  pt.x = evt.clientX; pt.y = evt.clientY;
  const p = pt.matrixTransform(svg.getScreenCTM().inverse());
  const gLon = (p.x / W) * 360 - 180;
  const gLat = 90 - (p.y / H) * 180;

  const target = order[roundIdx];
  const km = haversine(gLat, gLon, target.lat, target.lon);
  const v = verdictFor(km);
  const pts = scoreFor(km);
  scores.push(pts);

  const tp = project(target.lon, target.lat);

  const markers = document.getElementById('markers');
  markers.innerHTML = `
    <circle class="ping" cx="${p.x}" cy="${p.y}" r="2"/>
    <line class="link-line" x1="${p.x}" y1="${p.y}" x2="${tp.x}" y2="${tp.y}"/>
    <g class="pin-guess">
      <circle class="ring" cx="${p.x}" cy="${p.y}" r="9"/>
      <circle class="core" cx="${p.x}" cy="${p.y}" r="3.5"/>
    </g>
    <g class="pin-target">
      <circle class="ring" cx="${tp.x}" cy="${tp.y}" r="9"/>
      <circle class="core" cx="${tp.x}" cy="${tp.y}" r="3.5"/>
    </g>
  `;

  document.getElementById('verdict-text').textContent = `${v.label}  (${Math.round(km)} km away · +${pts} pts)`;
  document.getElementById('verdict-text').className = 'verdict ' + v.cls;
  document.getElementById('fact-text').textContent = target.fact;
  document.getElementById('feedback').classList.add('show');
  document.getElementById('tap-hint').style.display = 'none';
  document.getElementById('next-btn').style.display = 'inline-block';
  document.getElementById('next-btn').textContent = roundIdx === order.length-1 ? 'See Results →' : 'Next Strait →';

  const avg = Math.round(scores.reduce((a,b)=>a+b,0)/scores.length);
  document.getElementById('score-live').textContent = avg + '%';

  updateDots();
}

function nextRound(){
  roundIdx++;
  if(roundIdx >= order.length){
    endGame();
    return;
  }
  loadRound();
}

function endGame(){
  const avg = Math.round(scores.reduce((a,b)=>a+b,0)/scores.length);
  document.getElementById('final-score').textContent = avg + '%';
  let msg;
  if(avg >= 85) msg = "Master navigator. You could chart these waters blind.";
  else if(avg >= 65) msg = "Sharp sense of the map — a seasoned navigator's eye.";
  else if(avg >= 40) msg = "Solid run. The world's straits are tricky — chart again to sharpen your eye.";
  else msg = "The oceans are vast. Take another pass and lock in those coordinates.";
  document.getElementById('final-msg').textContent = msg;
  document.getElementById('screen-end').classList.remove('hidden');
}

/* ---------------- Responsive map mode ---------------- */
function applyMapMode(){
  const mobile = window.innerWidth < 820;
  document.getElementById('map-viewport').classList.toggle('mobile', mobile);
}
window.addEventListener('resize', applyMapMode);

/* ---------------- Init ---------------- */
drawGraticule();
drawLandmasses();
applyMapMode();
</script>
</body>
</html>
